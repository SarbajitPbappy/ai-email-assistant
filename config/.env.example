# 📧 AI Email Assistant - Environment Configuration
# Copy this file to config/.env and fill in your credentials

# ========================================
# LLM Configuration
# ========================================
# Options: ollama, openai, gemini, claude
PRIMARY_LLM=ollama
BACKUP_LLM=gemini

# Local Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3

# Cloud LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ========================================
# Gmail Configuration
# ========================================
# Get these from Google Cloud Console
# https://console.cloud.google.com
GMAIL_CREDENTIALS_FILE=config/credentials.json
GMAIL_TOKEN_FILE=config/token.json
USER_EMAIL=your_email@gmail.com

# ========================================
# Telegram Bot Configuration
# ========================================
# Get bot token from BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ========================================
# User Information
# ========================================
USER_NAME=Your Name
EMAIL_SIGNATURE=Best regards,
Your Name

# ========================================
# Firebase Configuration
# ========================================
FIREBASE_KEY_PATH=config/firebase_key.json

# ========================================
# Email Processing Settings
# ========================================
# Minimum match score for job opportunities (0.0 - 1.0)
MIN_MATCH_SCORE=0.70

# Enable/disable auto features
AUTO_APPLY_ENABLED=false
MAX_DAILY_APPLICATIONS=10
AUTO_REPLY_ENABLED=false
REPLY_REVIEW_MODE=true

# Email check interval in minutes
EMAIL_CHECK_INTERVAL_MINUTES=15

# ========================================
# CV and Research Profile Paths
# ========================================
CV_PATH=data/my_cv.pdf
RESEARCH_PROFILE_PATH=data/research_profile.json

# ========================================
# Application Paths
# ========================================
BASE_DIR=./
DATA_DIR=./data
LOG_DIR=./logs
